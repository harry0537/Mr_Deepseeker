# DeepSeek API key — get one free at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# Optional fallbacks (any one is sufficient)
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Ollama model to use for local fallback (default: qwen2.5:1.5b)
OLLAMA_MODEL=qwen2.5:1.5b

# Root of the project you want to review (absolute path)
MR_DEEPSEEKER_PROJECT_ROOT=/path/to/your/project
